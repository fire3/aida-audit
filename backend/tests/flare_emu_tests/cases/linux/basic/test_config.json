{
    "description": "Basic arithmetic and memory operations (Linux)",
    "source": "test_basic.c",
    "targets": {
        "linux": {
            "binary": "test_basic.so",
            "build_cmd": "gcc -shared -o test_basic.so test_basic.c"
        }
    },
    "tests": [
        {
            "name": "test_add",
            "description": "Simple addition",
            "args": [10, 20],
            "expected_return": 30
        },
        {
            "name": "test_strlen",
            "description": "String length",
            "args": [{"type": "string", "value": "Hello World"}],
            "expected_return": 11
        },
        {
            "name": "test_xor_crypt",
            "description": "XOR encryption (in-place modification)",
            "args": [
                {"type": "bytes", "value": "AAAA", "check_content": true},
                4,
                16
            ],
            "expected_memory": {
                "arg_index": 0,
                "content": "QQQQ" 
            }
        },
        {
            "name": "test_fib",
            "description": "Fibonacci recursion",
            "args": [10],
            "expected_return": 55
        },
        {
            "name": "test_many_args",
            "description": "Stack argument test",
            "args": [1, 2, 3, 4, 5, 6],
            "expected_return": 21
        },
        {
            "name": "test_complex_path",
            "description": "Loop execution",
            "args": [5],
            "expected_return": 10
        }
    ]
}
