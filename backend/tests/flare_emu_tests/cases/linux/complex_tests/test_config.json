{
    "description": "Complex Linux tests (globals, strings, structs, loops)",
    "source": "complex_tests.c",
    "targets": {
        "linux": {
            "binary": "complex_tests",
            "build_cmd": "gcc -static -o complex_tests complex_tests.c"
        }
    },
    "tests": [
        {
            "name": "get_constant",
            "description": "Simple return 42",
            "args": [],
            "expected_return": 42
        },
        {
            "name": "get_global_init",
            "description": "Initialized global should be 123",
            "args": [],
            "expected_return": 123
        },
        {
            "name": "get_global_counter",
            "description": "Initial global counter (bss) should be 0",
            "args": [],
            "expected_return": 0
        },
        {
            "name": "increment_global_counter",
            "description": "Increment global counter",
            "args": [],
            "expected_return": null
        },
        {
            "name": "get_global_counter",
            "description": "Global counter should be 1 after increment",
            "args": [],
            "expected_return": 1
        },
        {
            "name": "set_global_buffer",
            "description": "Set global buffer (bss) to 'ABC'",
            "args": [
                { "type": "string", "value": "ABC" }
            ],
            "expected_return": null
        },
        {
            "name": "get_global_buffer_first_char",
            "description": "Check global buffer first char is 'A' (65)",
            "args": [],
            "expected_return": 65
        },
        {
            "name": "use_strlen",
            "description": "Test strlen with 'hello'",
            "args": [
                { "type": "string", "value": "hello" }
            ],
            "expected_return": 5
        },
        {
            "name": "use_strcmp",
            "description": "Test strcmp with equal strings",
            "args": [
                { "type": "string", "value": "test" },
                { "type": "string", "value": "test" }
            ],
            "expected_return": 0
        },
        {
            "name": "reverse_string",
            "description": "Reverse 'hello' -> 'olleh'",
            "args": [
                { "type": "string", "value": "hello" }
            ],
            "expected_memory": {
                "arg_index": 0,
                "content": "olleh"
            }
        },
        {
            "name": "process_point",
            "description": "Test struct Point {x=10, y=20} -> x+=10, y+=20 -> return 20+40=60",
            "args": [
                { "type": "bytes", "value": "\u000A\u0000\u0000\u0000\u0014\u0000\u0000\u0000" } 
            ],
            "expected_return": 60
        },
        {
            "name": "sum_array",
            "description": "Sum array [1, 2, 3, 4, 5]",
            "args": [
                { "type": "bytes", "value": "\u0001\u0000\u0000\u0000\u0002\u0000\u0000\u0000\u0003\u0000\u0000\u0000\u0004\u0000\u0000\u0000\u0005\u0000\u0000\u0000" },
                5
            ],
            "expected_return": 15
        },
        {
            "name": "factorial_loop",
            "description": "Factorial of 5",
            "args": [5],
            "expected_return": 120
        }
    ]
}
