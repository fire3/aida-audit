{
  "binary": "test_dsl_demo",
  "source": "test_basic.c",
  "targets": {
    "linux": {
      "build_cmd": "gcc -g -O0 -shared -fPIC -o test_dsl_demo test_basic.c",
      "binary": "test_dsl_demo"
    }
  },
  "tests": [
    {
      "name": "test_add_text_dsl",
      "script": "$res = call test_add(10, 20)\nassert $res == 30"
    },
    {
      "name": "test_strlen_text_dsl",
      "script": "$str = alloc(\"hello world\")\n$len = call test_strlen($str)\nassert $len == 11"
    },
    {
        "name": "test_hooks_text_dsl",
        "script": "$res = call test_add(10, 20) {\n  hook test_add {\n    action: write_reg reg.edi = 100\n  }\n}\nassert $res == 120"
    }
  ]
}
