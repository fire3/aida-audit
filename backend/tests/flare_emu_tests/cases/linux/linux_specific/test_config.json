{
    "description": "Linux specific tests (long type size)",
    "source": "test_linux.c",
    "targets": {
        "linux": {
            "binary": "test_linux.so",
            "build_cmd": "gcc -shared -o test_linux.so test_linux.c"
        }
    },
    "tests": [
        {
            "name": "get_long_size",
            "description": "Check long size (should be 8 on Linux x64)",
            "args": [],
            "expected_return": 8
        },
        {
            "name": "add_longs",
            "description": "Add longs (large numbers requiring 64-bit long)",
            "args": [10000000000, 20000000000],
            "expected_return": 30000000000
        },
        {
            "name": "is_linux",
            "description": "Confirm Linux platform",
            "args": [],
            "expected_return": 1
        }
    ]
}
