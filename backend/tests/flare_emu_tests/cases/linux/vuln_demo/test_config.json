{
  "binary": "vuln_test",
  "source": "vuln.c",
  "targets": {
    "linux": {
      "build_cmd": "gcc -g -O0 -shared -fPIC -o vuln_test vuln.c",
      "binary": "vuln_test"
    }
  },
  "tests": [
    {
      "name": "test_coverage_report",
      "description": "Test coverage collection",
      "options": {
          "coverage": true
      },
      "steps": [
        {
          "type": "call",
          "function": "path_coverage",
          "args": [11, 5]
        },
        {
            "type": "report",
            "file": "coverage_report.json",
            "format": "json"
        }
      ]
    },
    {
      "name": "test_trace_log",
      "description": "Test execution tracing",
      "options": {
          "trace": true,
          "trace_mem": true
      },
      "steps": [
        {
          "type": "call",
          "function": "path_coverage",
          "args": [5, 11]
        },
        {
            "type": "report",
            "file": "trace_report.json",
            "include_trace": true
        }
      ]
    },
    {
      "name": "test_crash_detection",
      "description": "Test crash context capture (Stack Overflow)",
      "options": {
          "trace": true
      },
      "steps": [
        {
            "type": "alloc",
            "content": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
            "var": "bad_input"
        },
        {
          "type": "call",
          "function": "vuln_strcpy",
          "args": [{"type": "ptr", "value": "$bad_input"}]
        }
      ]
    }
  ]
}
